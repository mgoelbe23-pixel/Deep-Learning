import numpy as np

# X represents the input feature
# Range 0–10 chosen to show fast early change and later saturation
np.random.seed(42)
X = np.linspace(0, 10, 50).reshape(-1, 1)  # reshape means make it 1 column and then it will decide number or rows latter on its own

#np.random.normal(mean, std_dev, size)
noise = np.random.normal(0, 0.2, size=(50,1))
y = np.log(X + 1) + noise

# This target cannot be fit well by a straight line because logarithmic growth is steep initially and then flattens

print("X shape:", X.shape)
print("y shape:", y.shape)
print(X[:5])
print(y[:5])
# Number of hidden units: 3

# One unit behaves almost like a linear model. Multiple units allow the model to combine different behaviours and bend to match the curved data.

# Why not too many?
# Too many units increase complexity and instability; too few cannot bend enough.
W1 = np.random.uniform(-1,1, size=(1,3))
b1 = np.zeros((1,3))

W2 = np.random.uniform(-1,1, size=(3,1))
b2 = np.zeros((1,1))

# Weights affect shape (slope and bending). Biases shift the curve up or down


def activation(z):
    return np.maximum(0, z)

def activation_slope(z):
    return (z > 0).astype(float)

# Without a slope, the model has no direction signal telling it how to change parameters


# Forward pass

# z1 = XW1 + b1
z1 = X @ W1 + b1

# h = activation(z1)
h = activation(z1)

# y_hat = hW2 + b2
y_hat = h @ W2 + b2


error = y_hat - y

loss = np.mean(error ** 2)

# Squaring amplifies large mistakes, forcing the model to correct them more aggressively
# dL/dy_hat  (derivative of MSE)
dL_dy = 2 * error / len(X)

dL_dW2 = h.T @ dL_dy
dL_db2 = np.sum(dL_dy, axis=0, keepdims=True)

# Because output is produced from hidden activations, so changing hidden values changes the prediction

dL_dh = dL_dy @ W2.T

dL_dz1 = dL_dh * activation_slope(z1)

# Activation decides where error is allowed to pass; zero slope blocks learning in that region

dL_dW1 = X.T @ dL_dz1
dL_db1 = np.sum(dL_dz1, axis=0, keepdims=True)


learning_rate = 0.01

W1 -= learning_rate * dL_dW1
b1 -= learning_rate * dL_db1
W2 -= learning_rate * dL_dW2
b2 -= learning_rate * dL_db2

# move opposite to error

epochs = 1000
learning_rate = 0.01

# epochs large enough for learning but not excessive
# learning rate small enough for stable updates but large enough to converge

for epoch in range(epochs):

    z1 = X @ W1 + b1
    h = activation(z1)
    y_hat = h @ W2 + b2

    error = y_hat - y
    loss = np.mean(error ** 2)

    dL_dy = 2 * error / len(X)
    dL_dW2 = h.T @ dL_dy
    dL_db2 = np.sum(dL_dy, axis=0, keepdims=True)
    dL_dh = dL_dy @ W2.T
    dL_dz1 = dL_dh * activation_slope(z1)
    dL_dW1 = X.T @ dL_dz1
    dL_db1 = np.sum(dL_dz1, axis=0, keepdims=True)

    W1 -= learning_rate * dL_dW1
    b1 -= learning_rate * dL_db1
    W2 -= learning_rate * dL_dW2
    b2 -= learning_rate * dL_db2

    if epoch % 100 == 0:
        print(epoch, loss)
